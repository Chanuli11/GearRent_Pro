<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?> <?import javafx.scene.control.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.gearrent.controller.CustomerController" prefWidth="950" prefHeight="600">
  <top><HBox spacing="10" style="-fx-padding:10;"><Button text="« Back" onAction="#back"/><Label text="Customer Management" style="-fx-font-size:18; -fx-font-weight:bold;"/></HBox></top>
  <center>
    <VBox spacing="10" style="-fx-padding:10;">
      <HBox spacing="6">
        <TextField fx:id="name" promptText="Name"/>
        <TextField fx:id="nic" promptText="NIC/Passport"/>
        <TextField fx:id="contact" promptText="Contact"/>
        <TextField fx:id="email" promptText="Email"/>
        <TextField fx:id="address" promptText="Address"/>
        <ComboBox fx:id="membership" promptText="Membership"/>
        <Button text="Save" onAction="#save"/><Button text="Update" onAction="#update"/>
        <Button text="Delete" onAction="#delete"/><Button text="Clear" onAction="#clear"/>
      </HBox>
      <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="cId" text="ID" prefWidth="50"/>
          <TableColumn fx:id="cName" text="Name" prefWidth="180"/>
          <TableColumn fx:id="cNic" text="NIC" prefWidth="120"/>
          <TableColumn fx:id="cContact" text="Contact" prefWidth="110"/>
          <TableColumn fx:id="cEmail" text="Email" prefWidth="180"/>
          <TableColumn fx:id="cMember" text="Membership" prefWidth="100"/>
          <TableColumn fx:id="cDeposit" text="Active Deposit" prefWidth="120"/>
        </columns>
      </TableView>
    </VBox>
  </center>
</BorderPane>
