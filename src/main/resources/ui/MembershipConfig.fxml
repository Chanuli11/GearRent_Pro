<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?> <?import javafx.scene.control.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.gearrent.controller.MembershipConfigController" prefWidth="600" prefHeight="400">
  <top><HBox spacing="10" style="-fx-padding:10;"><Button text="« Back" onAction="#back"/><Label text="Membership Config" style="-fx-font-size:18; -fx-font-weight:bold;"/></HBox></top>
  <center>
    <VBox spacing="10" style="-fx-padding:10;">
      <HBox spacing="6">
        <ComboBox fx:id="levelBox" promptText="Level"/>
        <TextField fx:id="discount" promptText="Discount %"/>
        <Button text="Update" onAction="#update"/>
      </HBox>
      <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="cLevel" text="Level" prefWidth="200"/>
          <TableColumn fx:id="cDisc" text="Discount %" prefWidth="200"/>
        </columns>
      </TableView>
    </VBox>
  </center>
</BorderPane>
