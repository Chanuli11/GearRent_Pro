<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?> <?import javafx.scene.control.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.gearrent.controller.RentalController" prefWidth="1100" prefHeight="650">
  <top><HBox spacing="10" style="-fx-padding:10;"><Button text="« Back" onAction="#back"/><Label text="Rental Management" style="-fx-font-size:18; -fx-font-weight:bold;"/></HBox></top>
  <center>
    <VBox spacing="10" style="-fx-padding:10;">
      <HBox spacing="6">
        <ComboBox fx:id="branchBox" promptText="Branch"/>
        <ComboBox fx:id="equipmentBox" promptText="Equipment"/>
        <ComboBox fx:id="customerBox" promptText="Customer"/>
        <DatePicker fx:id="startDate" promptText="Start"/>
        <DatePicker fx:id="endDate" promptText="End"/>
        <Button text="Quote" onAction="#quote"/>
        <Button text="Create Rental" onAction="#create"/>
        <Label fx:id="quoteLabel"/>
      </HBox>
      <HBox spacing="6">
        <Label text="Filter Status:"/>
        <ComboBox fx:id="statusFilter" promptText="All"/>
        <Button text="Apply" onAction="#load"/>
      </HBox>
      <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="cId" text="ID" prefWidth="50"/>
          <TableColumn fx:id="cEq" text="Equipment" prefWidth="180"/>
          <TableColumn fx:id="cCust" text="Customer" prefWidth="160"/>
          <TableColumn fx:id="cBranch" text="Branch" prefWidth="120"/>
          <TableColumn fx:id="cFrom" text="From" prefWidth="100"/>
          <TableColumn fx:id="cTo" text="To" prefWidth="100"/>
          <TableColumn fx:id="cAmt" text="Final" prefWidth="90"/>
          <TableColumn fx:id="cPay" text="Payment" prefWidth="100"/>
          <TableColumn fx:id="cStatus" text="Status" prefWidth="100"/>
        </columns>
      </TableView>
    </VBox>
  </center>
</BorderPane>
